{
    "name": "pmp-security-tests",
    "version": "1.0.0",
    "description": "Security test suites for PMP platform, split into mock, service, and live proof levels",
    "scripts": {
        "test": "npm run test:offline",
        "test:offline": "jest --config jest.config.js --runInBand",
        "test:mock": "jest --config jest.mock.config.js --runInBand",
        "test:service": "jest --config jest.service.config.js --runInBand",
        "test:live": "jest --config jest.live.config.js --runInBand",
        "test:all": "npm run test:mock && npm run test:service && npm run test:live",
        "test:watch": "jest --config jest.config.js --watch"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^18.15.11",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4"
    }
}
