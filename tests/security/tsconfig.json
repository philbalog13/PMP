{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "./**/*.ts",
        "../../backend/monitoring-service/src/utils/pan-masking.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
