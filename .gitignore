# Environment variables
.env
.env.local
.env.*.local

# Keep the example
!.env.example

# Dependencies
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/

# Debug and Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.pnpm-debug.log*
logs/

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local tooling / assistant config (never commit)
.claude/

# Local debug artifacts
login.json
token.json
nul
.tmp_api_logs.txt
.tmp_thm/
tmp/

# Test coverage
coverage/
test-results/

# Generated local evidence
docs/test-evidence/*-runtime-evidence/

# Let's Encrypt material (private keys/certs)
certbot/conf/*
!certbot/conf/.gitkeep
certbot/www/*
!certbot/www/.gitkeep
