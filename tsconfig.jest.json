{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "typeRoots": ["./tests/integration/node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@jest/globals": ["tests/integration/node_modules/@jest/globals"],
      "axios": ["backend/sim-issuer-service/node_modules/axios"],
      "@/*": ["frontend/tpe-web/*"]
    }
  },
  "include": [
    "setupTests.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist"
  ]
}
